@model PlastiPack.API.Models.Pedido
@{
    ViewData["Title"] = "Nuevo Pedido";
    ViewData["ActivePage"] = "Pedidos";
    var fechaMin = DateTime.Today.AddDays(15).ToString("yyyy-MM-dd");
}

<div class="page-header">
    <div class="page-header-left">
        <p class="breadcrumb-custom">
            <a asp-action="Index">Pedidos</a> / Nuevo
        </p>
        <h1>Nuevo Pedido</h1>
        <p>Complete los campos y agregue los ítems del pedido</p>
    </div>
</div>

<!-- ── MODAL NUEVO CLIENTE ── -->
<div id="modal-nuevo-cliente"
     style="display:none; position:fixed; inset:0; z-index:1000;
            background:rgba(0,0,0,.45); align-items:center; justify-content:center">
    <div style="background:var(--color-white); border-radius:12px; padding:28px;
                width:100%; max-width:560px; box-shadow:0 8px 32px rgba(0,0,0,.2); position:relative">

        <!-- Cabecera modal -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px">
            <h3 style="margin:0; font-size:17px"><i class="bi bi-person-plus"></i> Nuevo Cliente</h3>
            <button type="button" id="btn-cerrar-modal"
                    style="background:none; border:none; font-size:20px; cursor:pointer; color:var(--color-mid)">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- Alerta errores modal -->
        <div id="modal-alert" style="display:none" class="alert-custom alert-error">
            <i class="bi bi-x-circle-fill"></i>
            <div id="modal-alert-msg"></div>
        </div>

        <!-- Formulario modal -->
        <div class="form-grid-3" style="gap:14px">
            <div class="form-group" style="grid-column: span 2; margin:0">
                <label class="form-label-custom">Nombre *</label>
                <input type="text" id="nc-nombre" class="form-control-custom"
                       placeholder="Razón social o nombre completo"/>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label-custom">NIT</label>
                <input type="text" id="nc-nit" class="form-control-custom"
                       placeholder="900.123.456-7"/>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label-custom">Teléfono</label>
                <input type="text" id="nc-telefono" class="form-control-custom"
                       placeholder="300 000 0000"/>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label-custom">Correo electrónico</label>
                <input type="email" id="nc-email" class="form-control-custom"
                       placeholder="contacto@empresa.com"/>
            </div>
            <div class="form-group" style="grid-column: span 3; margin:0">
                <label class="form-label-custom">Dirección</label>
                <input type="text" id="nc-direccion" class="form-control-custom"
                       placeholder="Calle, carrera, barrio, ciudad"/>
            </div>
        </div>

        <!-- Botones modal -->
        <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:20px">
            <button type="button" class="btn-secondary-custom" id="btn-cancelar-modal">
                <i class="bi bi-x-lg"></i> Cancelar
            </button>
            <button type="button" class="btn-primary-custom" id="btn-guardar-cliente">
                <i class="bi bi-check-lg"></i> Guardar Cliente
            </button>
        </div>
    </div>
</div>

<form asp-action="Crear" method="post" id="form-pedido">
    @Html.AntiForgeryToken()

    <!-- Errores globales -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-custom alert-error" style="margin-bottom:16px">
            <i class="bi bi-x-circle-fill"></i>
            <div>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <!-- Encabezado del pedido -->
    <div class="card-custom">
        <p class="card-custom-title"><i class="bi bi-file-earmark-text"></i> Encabezado del Pedido</p>
        <div class="form-grid-3">

            <!-- Destino -->
            <div class="form-group">
                <label class="form-label-custom">Destino *</label>
                <select asp-for="Destino" class="form-control-custom" id="sel-destino" required>
                    <option value="externo">Externo</option>
                    <option value="interno">Interno</option>
                </select>
                <span asp-validation-for="Destino" style="color:var(--color-danger); font-size:12px"></span>
            </div>

            <!-- Cliente (solo destino externo) -->
            <div class="form-group" id="bloque-cliente" style="grid-column: span 2">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px">
                    <label class="form-label-custom" style="margin:0">Cliente *</label>
                    <button type="button" class="btn-secondary-custom" id="btn-nuevo-cliente"
                            style="padding:4px 10px; font-size:12px">
                        <i class="bi bi-person-plus"></i> Nuevo cliente
                    </button>
                </div>
                <div style="position:relative">
                    <input type="text" id="input-buscar-cliente" class="form-control-custom"
                           placeholder="Buscar por nombre o NIT..."
                           autocomplete="off"/>
                    <input type="hidden" id="hidden-cliente-id" name="ClienteId" value=""/>
                    <div id="resultados-cliente"
                         style="display:none; position:absolute; z-index:100; width:100%;
                                background:var(--color-white); border:1px solid var(--color-border);
                                border-radius:8px; box-shadow:0 4px 16px rgba(0,0,0,.1); margin-top:4px;
                                max-height:220px; overflow-y:auto">
                    </div>
                </div>
                <span id="cliente-seleccionado-label"
                      style="font-size:12px; color:var(--color-mid); margin-top:4px; display:none">
                </span>
                <span asp-validation-for="ClienteId" style="color:var(--color-danger); font-size:12px"></span>
            </div>

            <!-- Fecha entrega -->
            <div class="form-group">
                <label class="form-label-custom">Fecha de Entrega * <small style="color:var(--color-mid)">(mín. 15 días)</small></label>
                <input asp-for="FechaEntrega" type="date" class="form-control-custom"
                       min="@fechaMin" required/>
                <span asp-validation-for="FechaEntrega" style="color:var(--color-danger); font-size:12px"></span>
            </div>

            <!-- Observaciones -->
            <div class="form-group" style="grid-column: span 3">
                <label class="form-label-custom">Observaciones</label>
                <textarea asp-for="Observaciones" class="form-control-custom"
                          rows="2" placeholder="Indicaciones especiales, embalaje, transporte..."></textarea>
            </div>
        </div>
    </div>

    <!-- Ítems del pedido -->
    <div class="card-custom">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px">
            <p class="card-custom-title" style="margin:0"><i class="bi bi-list-check"></i> Ítems del Pedido</p>
            <button type="button" class="btn-primary-custom" id="btn-agregar-item">
                <i class="bi bi-plus-lg"></i> Agregar Ítem
            </button>
        </div>

        <!-- Buscador de referencia -->
        <div id="buscador-ref" style="display:none; background:var(--color-light); border:1px solid var(--color-border); border-radius:8px; padding:16px; margin-bottom:16px">
            <div style="display:flex; gap:12px; align-items:flex-end">
                <div class="form-group" style="flex:1; margin:0">
                    <label class="form-label-custom">Buscar Referencia</label>
                    <input type="text" id="input-buscar-ref" class="form-control-custom"
                           placeholder="Código o nombre de referencia..."/>
                </div>
                <button type="button" class="btn-secondary-custom" id="btn-cancelar-busqueda">
                    <i class="bi bi-x-lg"></i> Cancelar
                </button>
            </div>
            <div id="resultados-ref" style="margin-top:8px"></div>
        </div>

        <!-- Tabla de ítems -->
        <div id="tabla-items-wrapper">
            <table class="table-custom" id="tabla-items">
                <thead>
                    <tr>
                        <th>Referencia</th>
                        <th style="width:120px; text-align:center">Stock</th>
                        <th style="width:120px">Cantidad</th>
                        <th style="width:140px">Precio Unit.</th>
                        <th style="width:130px; text-align:right">Subtotal</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody id="tbody-items">
                    <tr id="fila-vacia">
                        <td colspan="6" style="text-align:center; color:var(--color-mid); padding:24px">
                            <i class="bi bi-cart-plus" style="font-size:24px; display:block; margin-bottom:6px"></i>
                            Haga clic en "Agregar Ítem" para buscar referencias
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="4" style="text-align:right; font-weight:600; padding:12px 8px">Total:</td>
                        <td style="text-align:right; font-weight:700; font-size:16px; color:var(--color-primary)" id="total-pedido">$0</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div style="display:flex; gap:12px; justify-content:flex-end; margin-bottom:32px">
        <a asp-action="Index" class="btn-secondary-custom">
            <i class="bi bi-x-lg"></i> Cancelar
        </a>
        <button type="submit" class="btn-primary-custom" id="btn-guardar">
            <i class="bi bi-check-lg"></i> Crear Pedido
        </button>
    </div>
</form>

@section Scripts {
<script>
(function () {
    // ── Estado ──
    let items = [];
    let debounceTimer   = null;
    let debounceCliente = null;

    // ── DOM refs generales ──
    const selDestino    = document.getElementById('sel-destino');
    const bloqueCliente = document.getElementById('bloque-cliente');
    const btnAgregar    = document.getElementById('btn-agregar-item');
    const buscadorRef   = document.getElementById('buscador-ref');
    const inputBuscar   = document.getElementById('input-buscar-ref');
    const resultadosRef = document.getElementById('resultados-ref');
    const btnCancelar   = document.getElementById('btn-cancelar-busqueda');
    const tbodyItems    = document.getElementById('tbody-items');
    const filaVacia     = document.getElementById('fila-vacia');
    const totalEl       = document.getElementById('total-pedido');
    const formPedido    = document.getElementById('form-pedido');

    // ── DOM refs cliente ──
    const inputBuscarCliente = document.getElementById('input-buscar-cliente');
    const hiddenClienteId    = document.getElementById('hidden-cliente-id');
    const resultadosCliente  = document.getElementById('resultados-cliente');
    const clienteLabel       = document.getElementById('cliente-seleccionado-label');

    // ── DOM refs modal ──
    const modalNuevoCliente  = document.getElementById('modal-nuevo-cliente');
    const btnNuevoCliente    = document.getElementById('btn-nuevo-cliente');
    const btnCerrarModal     = document.getElementById('btn-cerrar-modal');
    const btnCancelarModal   = document.getElementById('btn-cancelar-modal');
    const btnGuardarCliente  = document.getElementById('btn-guardar-cliente'); // ← falta esta línea
    const modalAlert         = document.getElementById('modal-alert');
    const modalAlertMsg      = document.getElementById('modal-alert-msg');
    // ── Helpers modal ──
    function abrirModal() {
        // Limpiar campos
        ['nc-nombre','nc-nit','nc-telefono','nc-email','nc-direccion'].forEach(id => {
            document.getElementById(id).value = '';
        });
        modalAlert.style.display = 'none';
        modalNuevoCliente.style.display = 'flex';
    }
    function cerrarModal() {
        modalNuevoCliente.style.display = 'none';
    }

    btnNuevoCliente.addEventListener('click', abrirModal);
    btnCerrarModal.addEventListener('click',  cerrarModal);
    btnCancelarModal.addEventListener('click', cerrarModal);

    // Cerrar modal al hacer clic en el fondo
    modalNuevoCliente.addEventListener('click', e => {
        if (e.target === modalNuevoCliente) cerrarModal();
    });

    // ── Guardar cliente vía AJAX ──
    btnGuardarCliente.addEventListener('click', async () => {
        const nombre = document.getElementById('nc-nombre').value.trim();
        if (!nombre) {
            modalAlertMsg.textContent = 'El nombre del cliente es obligatorio.';
            modalAlert.style.display  = '';
            return;
        }

        btnGuardarCliente.disabled   = true;
        btnGuardarCliente.innerHTML  = '<i class="bi bi-hourglass-split"></i> Guardando...';
        modalAlert.style.display     = 'none';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const body  = new URLSearchParams({
                Nombre:    nombre,
                Nit:       document.getElementById('nc-nit').value.trim(),
                Telefono:  document.getElementById('nc-telefono').value.trim(),
                Email:     document.getElementById('nc-email').value.trim(),
                Direccion: document.getElementById('nc-direccion').value.trim(),
                __RequestVerificationToken: token
            });

            const res  = await fetch('/Clientes/CrearAjax', { method: 'POST', body });
            const data = await res.json();

            if (!res.ok || data.error) {
                modalAlertMsg.textContent = data.error ?? 'Error al guardar el cliente.';
                modalAlert.style.display  = '';
                return;
            }

            // Seleccionar el cliente recién creado automáticamente
            hiddenClienteId.value      = data.id;
            inputBuscarCliente.value   = data.nombre + (data.nit ? ` (${data.nit})` : '');
            clienteLabel.textContent   = '✓ Cliente creado y seleccionado';
            clienteLabel.style.display = '';
            cerrarModal();
            items.forEach((_, i) => actualizarPrecio(i));

        } catch {
            modalAlertMsg.textContent = 'Error de conexión al guardar.';
            modalAlert.style.display  = '';
        } finally {
            btnGuardarCliente.disabled  = false;
            btnGuardarCliente.innerHTML = '<i class="bi bi-check-lg"></i> Guardar Cliente';
        }
    });

    // ── Destino: ocultar/mostrar bloque cliente ──
    function toggleCliente() {
        const esExterno = selDestino.value === 'externo';
        bloqueCliente.style.display    = esExterno ? '' : 'none';
        inputBuscarCliente.required    = esExterno;
        if (!esExterno) {
            hiddenClienteId.value           = '';
            inputBuscarCliente.value        = '';
            resultadosCliente.style.display = 'none';
            clienteLabel.style.display      = 'none';
        }
        items.forEach((_, i) => actualizarPrecio(i));
    }
    selDestino.addEventListener('change', toggleCliente);
    toggleCliente();

    // ── Búsqueda de clientes con debounce ──
    inputBuscarCliente.addEventListener('input', () => {
        clearTimeout(debounceCliente);
        hiddenClienteId.value = '';
        const q = inputBuscarCliente.value.trim();
        if (q.length < 2) { resultadosCliente.style.display = 'none'; return; }
        debounceCliente = setTimeout(() => buscarClientes(q), 300);
    });

    async function buscarClientes(q) {
        resultadosCliente.innerHTML    = '<p style="padding:10px 14px; font-size:13px; color:var(--color-mid)">Buscando...</p>';
        resultadosCliente.style.display = '';
        try {
            const res  = await fetch(`/Clientes/Buscar?q=${encodeURIComponent(q)}`);
            const data = await res.json();

            if (!data.length) {
                resultadosCliente.innerHTML = `
                    <p style="padding:10px 14px; font-size:13px; color:var(--color-mid)">
                        Sin resultados.
                        <a href="#" id="link-crear-desde-busqueda"
                           style="color:var(--color-primary); font-weight:600; margin-left:6px">
                           + Crear "${q}"
                        </a>
                    </p>`;
                document.getElementById('link-crear-desde-busqueda')?.addEventListener('click', e => {
                    e.preventDefault();
                    document.getElementById('nc-nombre').value = q;
                    resultadosCliente.style.display = 'none';
                    abrirModal();
                });
                return;
            }

            resultadosCliente.innerHTML = data.map(c => `
                <div class="cliente-result-item"
                     data-id="${c.id}" data-nombre="${c.nombre}" data-nit="${c.nit ?? ''}"
                     style="padding:10px 14px; cursor:pointer; font-size:13px;
                            border-bottom:1px solid var(--color-border);
                            display:flex; justify-content:space-between; align-items:center">
                    <span><strong>${c.nombre}</strong></span>
                    ${c.nit ? `<span style="color:var(--color-mid); font-size:12px">${c.nit}</span>` : ''}
                </div>`).join('');

            resultadosCliente.querySelectorAll('.cliente-result-item').forEach(el => {
                el.addEventListener('mouseenter', () => el.style.background = 'var(--color-light)');
                el.addEventListener('mouseleave', () => el.style.background = '');
                el.addEventListener('click', () => {
                    hiddenClienteId.value           = el.dataset.id;
                    inputBuscarCliente.value        = el.dataset.nombre + (el.dataset.nit ? ` (${el.dataset.nit})` : '');
                    resultadosCliente.style.display = 'none';
                    clienteLabel.textContent        = '✓ Cliente seleccionado';
                    clienteLabel.style.display      = '';
                    items.forEach((_, i) => actualizarPrecio(i));
                });
            });
        } catch {
            resultadosCliente.innerHTML = '<p style="padding:10px 14px; font-size:13px; color:var(--color-danger)">Error al buscar.</p>';
        }
    }

    // Cerrar dropdown al hacer clic fuera
    document.addEventListener('click', e => {
        if (!bloqueCliente.contains(e.target)) {
            resultadosCliente.style.display = 'none';
        }
    });

    // ── Abrir buscador de referencias ──
    btnAgregar.addEventListener('click', () => {
        buscadorRef.style.display = '';
        inputBuscar.value         = '';
        resultadosRef.innerHTML   = '';
        inputBuscar.focus();
    });

    btnCancelar.addEventListener('click', () => {
        buscadorRef.style.display = 'none';
    });

    // ── Búsqueda referencias con debounce ──
    inputBuscar.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        const q = inputBuscar.value.trim();
        if (q.length < 2) { resultadosRef.innerHTML = ''; return; }
        debounceTimer = setTimeout(() => buscarReferencias(q), 300);
    });

    async function buscarReferencias(q) {
        resultadosRef.innerHTML = '<p style="color:var(--color-mid); font-size:13px; padding:4px">Buscando...</p>';
        try {
            const res  = await fetch(`/Referencias/Buscar?q=${encodeURIComponent(q)}`);
            const data = await res.json();

            if (!data.length) {
                resultadosRef.innerHTML = '<p style="color:var(--color-mid); font-size:13px; padding:4px">Sin resultados.</p>';
                return;
            }

            resultadosRef.innerHTML = data.map(r => `
                <div class="ref-result-item" data-id="${r.id}" data-codigo="${r.codigo}"
                     data-nombre="${r.nombre ?? ''}" data-stock="${r.stock}"
                     style="padding:8px 12px; cursor:pointer; border-radius:6px; font-size:13px;
                            border:1px solid var(--color-border); margin-bottom:4px; background:var(--color-white);
                            display:flex; justify-content:space-between; align-items:center">
                    <span><strong>${r.codigo}</strong> — ${r.nombre ?? ''}</span>
                    <span style="color:${r.stock > 0 ? 'var(--color-success)' : 'var(--color-danger)'}; font-size:12px">
                        Stock: ${r.stock}
                    </span>
                </div>`).join('');

            resultadosRef.querySelectorAll('.ref-result-item').forEach(el => {
                el.addEventListener('mouseenter', () => el.style.background = 'var(--color-light)');
                el.addEventListener('mouseleave', () => el.style.background = 'var(--color-white)');
                el.addEventListener('click', () => seleccionarReferencia(
                    parseInt(el.dataset.id),
                    el.dataset.codigo,
                    el.dataset.nombre,
                    parseInt(el.dataset.stock)
                ));
            });
        } catch {
            resultadosRef.innerHTML = '<p style="color:var(--color-danger); font-size:13px">Error al buscar.</p>';
        }
    }

    async function seleccionarReferencia(id, codigo, nombre, stock) {
        if (items.find(i => i.referenciaId === id)) {
            alert('Esa referencia ya está en el pedido.');
            return;
        }
        const clienteId = hiddenClienteId.value || '';
        let precio = 0;
        try {
            const res = await fetch(`/Pedidos/PrecioSugerido?referenciaId=${id}&clienteId=${clienteId}&destino=${selDestino.value}`);
            const data = await res.json();
            precio = data.precio ?? 0;
            stock  = data.stock  ?? stock;
        } catch {}

        items.push({ referenciaId: id, codigo, nombre, stock, cantidad: 1, precio });
        buscadorRef.style.display = 'none';
        renderTabla();
    }

    async function actualizarPrecio(idx) {
        const item      = items[idx];
        const clienteId = hiddenClienteId.value || '';
        try {
            const res = await fetch(`/Pedidos/PrecioSugerido?referenciaId=${item.referenciaId}&clienteId=${clienteId}&destino=${selDestino.value}`);
            const data = await res.json();
            item.precio = data.precio ?? item.precio;
            item.stock  = data.stock  ?? item.stock;
            renderTabla();
        } catch {}
    }

    // ── Render tabla ──
    function renderTabla() {
        if (!items.length) {
            filaVacia.style.display = '';
            tbodyItems.querySelectorAll('tr.item-row').forEach(r => r.remove());
            totalEl.textContent = '$0';
            sincronizarInputsOcultos();
            return;
        }
        filaVacia.style.display = 'none';
        tbodyItems.querySelectorAll('tr.item-row').forEach(r => r.remove());

        let total = 0;
        items.forEach((item, idx) => {
            const subtotal = item.cantidad * item.precio;
            total += subtotal;
            const fila = document.createElement('tr');
            fila.className = 'item-row';
            fila.innerHTML = `
                <td>
                    <strong style="display:block">${item.codigo}</strong>
                    <small style="color:var(--color-mid)">${item.nombre}</small>
                </td>
                <td style="text-align:center">
                    <span style="color:${item.stock > 0 ? 'var(--color-success)' : 'var(--color-danger)'}; font-weight:600">
                        ${item.stock}
                    </span>
                </td>
                <td>
                    <input type="number" min="1" max="${item.stock}" value="${item.cantidad}"
                           class="form-control-custom input-cantidad" data-idx="${idx}"
                           style="width:90px"/>
                </td>
                <td>
                    <div style="position:relative">
                        <span style="position:absolute; left:10px; top:50%; transform:translateY(-50%); color:var(--color-mid)">$</span>
                        <input type="number" min="0" step="0.01" value="${item.precio.toFixed(2)}"
                               class="form-control-custom input-precio" data-idx="${idx}"
                               style="padding-left:22px; width:110px"/>
                    </div>
                </td>
                <td style="text-align:right; font-weight:600">
                    $${subtotal.toLocaleString('es-CO', {minimumFractionDigits:2, maximumFractionDigits:2})}
                </td>
                <td>
                    <button type="button" class="btn-icon-custom btn-icon-danger btn-eliminar" data-idx="${idx}" title="Eliminar">
                        <i class="bi bi-trash3"></i>
                    </button>
                </td>`;
            tbodyItems.appendChild(fila);
        });

        totalEl.textContent = '$' + total.toLocaleString('es-CO', {minimumFractionDigits:2, maximumFractionDigits:2});

        tbodyItems.querySelectorAll('.input-cantidad').forEach(inp => {
            inp.addEventListener('change', () => {
                const idx = parseInt(inp.dataset.idx);
                items[idx].cantidad = Math.max(1, parseInt(inp.value) || 1);
                renderTabla();
            });
        });
        tbodyItems.querySelectorAll('.input-precio').forEach(inp => {
            inp.addEventListener('change', () => {
                const idx = parseInt(inp.dataset.idx);
                items[idx].precio = Math.max(0, parseFloat(inp.value) || 0);
                renderTabla();
            });
        });
        tbodyItems.querySelectorAll('.btn-eliminar').forEach(btn => {
            btn.addEventListener('click', () => {
                items.splice(parseInt(btn.dataset.idx), 1);
                renderTabla();
            });
        });

        sincronizarInputsOcultos();
    }

    // ── Sincronizar inputs ocultos para el POST ──
    function sincronizarInputsOcultos() {
        formPedido.querySelectorAll('.hidden-item').forEach(el => el.remove());
        items.forEach((item, idx) => {
            const mkInput = (name, value) => {
                const el = document.createElement('input');
                el.type      = 'hidden';
                el.name      = name;
                el.value     = value;
                el.className = 'hidden-item';
                formPedido.appendChild(el);
            };
            mkInput(`referenciaIds[${idx}]`, item.referenciaId);
            mkInput(`cantidades[${idx}]`,    item.cantidad);
            mkInput(`precios[${idx}]`,       item.precio.toFixed(2));
        });
    }

    // ── Validar antes de enviar ──
    formPedido.addEventListener('submit', e => {
        if (!items.length) {
            e.preventDefault();
            alert('Debe agregar al menos un ítem al pedido.');
            return;
        }
        const stockErrors = items.filter(i => i.cantidad > i.stock);
        if (stockErrors.length) {
            e.preventDefault();
            alert('Stock insuficiente para: ' + stockErrors.map(i => i.codigo).join(', '));
        }
    });

})();
</script>
}