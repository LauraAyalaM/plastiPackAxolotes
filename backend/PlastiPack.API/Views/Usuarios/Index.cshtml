        </p>
    }
    else
    {
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Desde</th>
                    <th style="text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in operarios)
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px">
                                <div style="width:32px; height:32px; border-radius:50%;
                                            background:var(--color-warning, #f59e0b); color:#fff;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:13px; flex-shrink:0">
                                    @u.Nombre.Substring(0, 1).ToUpper()
                                </div>
                                <strong>@u.Nombre</strong>
                            </div>
                        </td>
                        <td style="color:var(--color-mid)">@u.Email</td>
                        <td>
                            <span class="badge-custom @(u.Activo ? "badge-success" : "badge-danger")">
                                @(u.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td style="color:var(--color-mid); font-size:13px">
                            @u.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                        </td>
                        <td style="text-align:right">
                            <form asp-action="CambiarEstado" asp-route-id="@u.Id"
                                  method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn-icon-custom @(u.Activo ? "btn-icon-danger" : "btn-icon-success")"
                                        title="@(u.Activo ? "Desactivar" : "Activar")">
                                    <i class="bi @(u.Activo ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>