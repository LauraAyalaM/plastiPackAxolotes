@using PlastiPack.API.Models
@model IEnumerable<Usuario>
@{
    ViewData["Title"] = "Usuarios";
    ViewData["ActivePage"] = "Usuarios";

    var vendedores = Model.Where(u => u.Rol?.Nombre == "vendedor").ToList();
    var operarios  = Model.Where(u => u.Rol?.Nombre == "operario").ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Usuarios</h1>
        <p>Gestión de vendedores y operarios del sistema</p>
    </div>
</div>

<!-- Tarjetas de referencia rápida -->
<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px">

    <!-- Jefe de producción (solo info) -->
    <div class="card-custom" style="border-left:4px solid var(--color-primary)">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px">
            <div style="width:40px; height:40px; border-radius:50%; background:var(--color-primary);
                        color:#fff; display:flex; align-items:center; justify-content:center; font-size:18px">
                <i class="bi bi-shield-check"></i>
            </div>
            <div>
                <p style="margin:0; font-weight:700; font-size:14px; color:var(--color-dark)">Jefe de Producción</p>
                <span class="badge-custom badge-info" style="font-size:11px">Admin</span>
            </div>
        </div>
        <p style="font-size:12px; color:var(--color-mid); margin:0 0 4px">
            <i class="bi bi-envelope"></i> admin@plastipack.com
        </p>
        <p style="font-size:12px; color:var(--color-mid); margin:0">
            <i class="bi bi-unlock"></i> Acceso completo al sistema
        </p>
    </div>

    <!-- Vendedor -->
    <div class="card-custom" style="border-left:4px solid var(--color-success)">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px">
            <div style="width:40px; height:40px; border-radius:50%; background:var(--color-success);
                        color:#fff; display:flex; align-items:center; justify-content:center; font-size:18px">
                <i class="bi bi-cart3"></i>
            </div>
            <div>
                <p style="margin:0; font-weight:700; font-size:14px; color:var(--color-dark)">Vendedor</p>
                <span class="badge-custom badge-success" style="font-size:11px">@vendedores.Count(u => u.Activo) activos</span>
            </div>
        </div>
        <p style="font-size:12px; color:var(--color-mid); margin:0 0 4px">
            <i class="bi bi-envelope"></i> vendedor@plastipack.com
        </p>
        <p style="font-size:12px; color:var(--color-mid); margin:0">
            <i class="bi bi-lock"></i> Módulo de Pedidos y Clientes
        </p>
    </div>

    <!-- Operario -->
    <div class="card-custom" style="border-left:4px solid var(--color-warning, #f59e0b)">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px">
            <div style="width:40px; height:40px; border-radius:50%; background:var(--color-warning, #f59e0b);
                        color:#fff; display:flex; align-items:center; justify-content:center; font-size:18px">
                <i class="bi bi-tools"></i>
            </div>
            <div>
                <p style="margin:0; font-weight:700; font-size:14px; color:var(--color-dark)">Operario</p>
                <span class="badge-custom badge-warning" style="font-size:11px">@operarios.Count(u => u.Activo) activos</span>
            </div>
        </div>
        <p style="font-size:12px; color:var(--color-mid); margin:0 0 4px">
            <i class="bi bi-envelope"></i> operario@plastipack.com
        </p>
        <p style="font-size:12px; color:var(--color-mid); margin:0">
            <i class="bi bi-lock"></i> Planillas y Registro de Sellado
        </p>
    </div>
</div>

<!-- Tabla de Vendedores -->
<div class="card-custom" style="margin-bottom:16px">
    <p class="card-custom-title">
        <i class="bi bi-cart3"></i> Vendedores
        <span style="margin-left:8px; font-size:12px; font-weight:400; color:var(--color-mid)">
            @vendedores.Count total — @vendedores.Count(u => u.Activo) activos
        </span>
    </p>

    @if (!vendedores.Any())
    {
        <p style="color:var(--color-mid); font-size:14px; padding:12px 0">
            No hay vendedores registrados.
        </p>
    }
    else
    {
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Desde</th>
                    <th style="text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in vendedores)
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px">
                                <div style="width:32px; height:32px; border-radius:50%;
                                            background:var(--color-success); color:#fff;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:13px; flex-shrink:0">
                                    @u.Nombre.Substring(0, 1).ToUpper()
                                </div>
                                <strong>@u.Nombre</strong>
                            </div>
                        </td>
                        <td style="color:var(--color-mid)">@u.Email</td>
                        <td>
                            <span class="badge-custom @(u.Activo ? "badge-success" : "badge-danger")">
                                @(u.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td style="color:var(--color-mid); font-size:13px">
                            @u.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                        </td>
                        <td style="text-align:right">
                            <form asp-action="CambiarEstado" asp-route-id="@u.Id"
                                  method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn-icon-custom @(u.Activo ? "btn-icon-danger" : "btn-icon-success")"
                                        title="@(u.Activo ? "Desactivar" : "Activar")">
                                    <i class="bi @(u.Activo ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Tabla de Operarios -->
<div class="card-custom">
    <p class="card-custom-title">
        <i class="bi bi-tools"></i> Operarios
        <span style="margin-left:8px; font-size:12px; font-weight:400; color:var(--color-mid)">
