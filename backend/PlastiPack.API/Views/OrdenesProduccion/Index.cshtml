@model IEnumerable<PlastiPack.API.Models.OrdenProduccion>
@{
    ViewData["Title"] = "Órdenes de Producción";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string BadgeOrden(string estado) => estado switch {
        "pendiente"   => "badge-warning",
        "en_proceso"  => "badge-info",
        "completada"  => "badge-success",
        "cancelada"   => "badge-danger",
        _             => "badge-warning"
    };
}

<div class="page-header">
    <div class="page-header-left">
        <div class="breadcrumb-custom"><a asp-controller="Home" asp-action="Index">Inicio</a> / Producción</div>
        <h1>Órdenes de Producción</h1>
        <p>@ViewBag.Total orden(es) encontradas</p>
    </div>
    @if (User.IsInRole("jefe_produccion"))
    {
        <a asp-action="Crear" class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Nueva Orden
        </a>
    }
</div>

<div class="card-custom">
    <form method="get" class="filter-bar">
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               placeholder="Buscar por referencia o pedido…" class="form-control-custom" />
        <select name="estado" class="form-control-custom">
            <option value="">Todos los estados</option>
            @foreach (var e in new[] { "pendiente","en_proceso","completada","cancelada" })
            {
                <option value="@e" selected="@(ViewBag.Estado == e)">@e</option>
            }
        </select>
        <button type="submit" class="btn-primary-custom">
            <i class="bi bi-search"></i> Filtrar
        </button>
        <a asp-action="Index" class="btn-secondary-custom">Limpiar</a>
    </form>

    <table class="table-custom">
        <thead>
            <tr>
                <th>#</th>
                <th>Pedido</th>
                <th>Referencia</th>
                <th>Cantidad</th>
                <th>Estado</th>
                <th>Creada</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td><strong>@o.Id</strong></td>
                    <td>Pedido #@o.PedidoId</td>
                    <td>@(o.Referencia?.Codigo ?? "—")</td>
                    <td>@o.CantidadRequerida</td>
                    <td><span class="@BadgeOrden(o.Estado)">@o.Estado</span></td>
                    <td>@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@o.Id"
                           class="btn-secondary-custom btn-sm-custom">
                            <i class="bi bi-eye"></i> Ver
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center;padding:32px;color:var(--color-mid);">
                        No hay órdenes que coincidan con los filtros.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ViewBag.TotalPaginas > 1)
    {
        <div class="pagination-custom">
            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
            {
                <a asp-action="Index"
                   asp-route-pagina="@i"
                   asp-route-estado="@ViewBag.Estado"
                   asp-route-busqueda="@ViewBag.Busqueda"
                   class="@(i == ViewBag.PaginaActual ? "active-page" : "")">@i</a>
            }
        </div>
    }
</div>
