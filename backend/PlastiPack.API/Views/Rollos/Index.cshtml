@model IEnumerable<PlastiPack.API.Models.Rollo>
@{
    ViewData["Title"] = "Rollos";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string BadgeRollo(string e) => e switch {
        "disponible"  => "badge-success",
        "en_proceso"  => "badge-info",
        "usado"       => "badge-warning",
        "defectuoso"  => "badge-danger",
        _             => "badge-warning"
    };
}

<div class="page-header">
    <div class="page-header-left">
        <div class="breadcrumb-custom"><a asp-controller="Home" asp-action="Index">Inicio</a> / Rollos</div>
        <h1>Gestión de Rollos</h1>
        <p>@ViewBag.Total rollo(s) encontrado(s)</p>
    </div>
    @if (User.IsInRole("jefe_produccion") || User.IsInRole("operario"))
    {
        <a asp-action="Crear" class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> Registrar Rollo
        </a>
    }
</div>

<div class="card-custom">
    <form method="get" class="filter-bar">
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               placeholder="N° rollo, referencia, marca…" class="form-control-custom" />
        <select name="estado" class="form-control-custom">
            <option value="">Todos los estados</option>
            @foreach (var e in new[] { "disponible","en_proceso","usado","defectuoso" })
            {
                <option value="@e" selected="@(ViewBag.Estado == e)">@e</option>
            }
        </select>
        <button type="submit" class="btn-primary-custom">
            <i class="bi bi-search"></i> Filtrar
        </button>
        <a asp-action="Index" class="btn-secondary-custom">Limpiar</a>
    </form>

    <table class="table-custom">
        <thead>
            <tr>
                <th>N° Rollo</th>
                <th>Referencia</th>
                <th>Impresión</th>
                <th>Marca</th>
                <th>Peso (kg)</th>
                <th>Estado</th>
                <th>Registrado</th>
                @if (User.IsInRole("jefe_produccion") || User.IsInRole("operario"))
                {
                    <th>Cambiar estado</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td><strong>@r.NumeroRollo</strong></td>
                    <td>@(r.Referencia?.Codigo ?? "—")</td>
                    <td>@(r.TieneImpresion ? "✔" : "—")</td>
                    <td>@(r.MarcaImpresa ?? "—")</td>
                    <td>@(r.PesoKg?.ToString("F2") ?? "—")</td>
                    <td><span class="@BadgeRollo(r.Estado)">@r.Estado</span></td>
                    <td>@r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    @if (User.IsInRole("jefe_produccion") || User.IsInRole("operario"))
                    {
                        <td>
                            <form asp-action="CambiarEstado" method="post" style="display:flex;gap:6px;margin:0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <select name="nuevoEstado" class="form-control-custom" style="max-width:130px;padding:4px 8px;">
                                    @foreach (var e in new[] { "disponible","en_proceso","usado","defectuoso" })
                                    {
                                        <option value="@e" selected="@(r.Estado == e)">@e</option>
                                    }
                                </select>
                                <button type="submit" class="btn-secondary-custom btn-sm-custom">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                            </form>
                        </td>
                    }
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" style="text-align:center;padding:32px;color:var(--color-mid);">
                        No hay rollos registrados.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ViewBag.TotalPaginas > 1)
    {
        <div class="pagination-custom">
            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
            {
                <a asp-action="Index"
                   asp-route-pagina="@i"
                   asp-route-estado="@ViewBag.Estado"
                   asp-route-busqueda="@ViewBag.Busqueda"
                   class="@(i == ViewBag.PaginaActual ? "active-page" : "")">@i</a>
            }
        </div>
    }
</div>
