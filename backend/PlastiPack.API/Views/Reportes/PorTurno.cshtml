@model IEnumerable<PlastiPack.API.Models.RegistroSellado>
@{
    ViewData["Title"] = "Reporte por Turno";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var resumen = (System.Collections.IEnumerable)ViewBag.ResumenPorSelladora;
}

<div class="page-header">
    <div class="page-header-left">
        <div class="breadcrumb-custom">
            <a asp-controller="Home" asp-action="Index">Inicio</a> /
            <a asp-action="Index">Reportes</a> / Por Turno
        </div>
        <h1>Reporte por Turno</h1>
        <p>@ViewBag.FechaDisplay</p>
    </div>
    <a asp-action="Index" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Reportes
    </a>
</div>

<div class="card-custom">
    <form method="get" class="filter-bar">
        <input type="date" name="fecha" value="@ViewBag.FechaFiltro" class="form-control-custom" />
        <select name="selladoaId" class="form-control-custom">
            <option value="">Todas las selladoras</option>
            @foreach (var s in (List<PlastiPack.API.Models.Selladora>)ViewBag.Selladoras)
            {
                <option value="@s.Id" selected="@(ViewBag.SelladoraId?.ToString() == s.Id.ToString())">
                    @s.Nombre
                </option>
            }
        </select>
        <button type="submit" class="btn-primary-custom">
            <i class="bi bi-search"></i> Consultar
        </button>
    </form>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
    <div class="card-custom" style="margin-bottom:0;text-align:center;">
        <div style="font-size:32px;font-weight:700;color:var(--color-primary);">@(((int)ViewBag.TotalUnidades).ToString("N0"))</div>
        <div style="font-size:var(--font-size-sm);color:var(--color-mid);">Unidades selladas</div>
    </div>
    <div class="card-custom" style="margin-bottom:0;text-align:center;">
        <div style="font-size:32px;font-weight:700;color:#D97706;">@(((decimal)ViewBag.TotalDesperdicio).ToString("N3")) kg</div>
        <div style="font-size:var(--font-size-sm);color:var(--color-mid);">Desperdicio total</div>
    </div>
    <div class="card-custom" style="margin-bottom:0;text-align:center;">
        <div style="font-size:32px;font-weight:700;color:#16A34A;">@Model.Count()</div>
        <div style="font-size:var(--font-size-sm);color:var(--color-mid);">Registros del día</div>
    </div>
</div>

@if (((System.Collections.IEnumerable)resumen).Cast<dynamic>().Any())
{
    <div class="card-custom">
        <div class="card-custom-title">Resumen por Selladora</div>
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Selladora</th>
                    <th>Registros</th>
                    <th>Unidades</th>
                    <th>Desperdicio</th>
                    <th>Operarios</th>
                </tr>
            </thead>
            <tbody>
                @foreach (dynamic item in resumen)
                {
                    <tr>
                        <td>
                            <span style="display:inline-flex;align-items:center;gap:6px;">
                                <i class="bi bi-tools" style="color:var(--color-primary)"></i>
                                <strong>@item.Selladora</strong>
                            </span>
                        </td>
                        <td>@item.NumRegistros</td>
                        <td><strong>@(((int)item.TotalUnidades).ToString("N0"))</strong></td>
                        <td>@(((decimal)item.TotalDesperdicio).ToString("N3")) kg</td>
                        <td>
                            @foreach (var op in (System.Collections.IEnumerable)item.Operarios)
                            {
                                <span class="badge-info" style="margin-right:4px;">@op</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="card-custom">
    <div class="card-custom-title">Detalle de Registros</div>
    <table class="table-custom">
        <thead>
            <tr>
                <th>Selladora</th>
                <th>Operario</th>
                <th>Referencia</th>
                <th>Rollo</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Unidades</th>
                <th>Desperdicio</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@(r.PlanillaItem?.Planilla?.Selladora?.Nombre ?? "—")</td>
                    <td>@(r.Operario?.Nombre ?? "—")</td>
                    <td><strong>@(r.PlanillaItem?.OrdenProceso?.OrdenProduccion?.Referencia?.Codigo ?? "—")</strong></td>
                    <td><span class="badge-info">@(r.NumeroRollo ?? "—")</span></td>                    <td>@r.HoraInicio.ToString("HH:mm")</td>
                    <td>@(r.HoraFin?.ToString("HH:mm") ?? "—")</td>
                    <td><strong>@(r.CantidadUnidades?.ToString("N0") ?? "—")</strong></td>
                    <td>@r.PesoDesperdicio.ToString("N3") kg</td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" style="text-align:center;padding:32px;color:var(--color-mid);">
                        No hay registros para la fecha seleccionada.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
