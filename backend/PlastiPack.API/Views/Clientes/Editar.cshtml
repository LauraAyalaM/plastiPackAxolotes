@model PlastiPack.API.Models.Cliente
@{
    ViewData["Title"] = "Editar Cliente";
    ViewData["ActivePage"] = "Clientes";
}

<div class="page-header">
    <div class="page-header-left">
        <p class="breadcrumb-custom">
            <a asp-action="Index">Clientes</a> / Editar
        </p>
        <h1>Editar Cliente</h1>
        <p>@Model.Nombre</p>
    </div>
</div>

<form asp-action="Editar" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden"/>

    <div class="card-custom">
        <p class="card-custom-title"><i class="bi bi-person-vcard"></i> Información del Cliente</p>
        <div class="form-grid-3">
            <div class="form-group" style="grid-column: span 2">
                <label class="form-label-custom">Nombre *</label>
                <input asp-for="Nombre" class="form-control-custom" required/>
                <span asp-validation-for="Nombre" style="color:var(--color-danger); font-size:12px"></span>
            </div>
            <div class="form-group">
                <label class="form-label-custom">NIT</label>
                <input asp-for="Nit" class="form-control-custom"/>
                <span asp-validation-for="Nit" style="color:var(--color-danger); font-size:12px"></span>
            </div>
            <div class="form-group">
                <label class="form-label-custom">Teléfono</label>
                <input asp-for="Telefono" class="form-control-custom"/>
            </div>
            <div class="form-group">
                <label class="form-label-custom">Correo electrónico</label>
                <input asp-for="Email" type="email" class="form-control-custom"/>
            </div>
            <div class="form-group" style="grid-column: span 2">
                <label class="form-label-custom">Dirección</label>
                <input asp-for="Direccion" class="form-control-custom"/>
            </div>
            <div class="form-group">
                <label class="form-label-custom">Estado</label>
                <select asp-for="Activo" class="form-control-custom">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
            </div>
        </div>
    </div>

    <div style="display:flex; gap:12px; justify-content:flex-end; margin-bottom:32px">
        <a asp-action="Index" class="btn-secondary-custom">
            <i class="bi bi-x-lg"></i> Cancelar
        </a>
        <button type="submit" class="btn-primary-custom">
            <i class="bi bi-check-lg"></i> Guardar Cambios
        </button>
    </div>
</form>
