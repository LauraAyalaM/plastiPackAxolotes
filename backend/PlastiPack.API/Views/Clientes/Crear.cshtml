@model PlastiPack.API.Models.Cliente
@{
    ViewData["Title"] = "Nuevo Cliente";
    ViewData["ActivePage"] = "Clientes";
}

<div class="page-header">
    <div class="page-header-left">
        <p class="breadcrumb-custom">
            <a asp-action="Index">Clientes</a> / Nuevo
        </p>
        <h1>Nuevo Cliente</h1>
        <p>Complete los campos para registrar un nuevo cliente</p>
    </div>
</div>

<form asp-action="Crear" method="post">
    @Html.AntiForgeryToken()

    <div class="card-custom">
        <p class="card-custom-title"><i class="bi bi-person-vcard"></i> Información del Cliente</p>
        <div class="form-grid-3">
            <div class="form-group" style="grid-column: span 2">
                <label class="form-label-custom">Nombre *</label>
                <input asp-for="Nombre" class="form-control-custom" required placeholder="Razón social o nombre completo"/>
                <span asp-validation-for="Nombre" style="color:var(--color-danger); font-size:12px"></span>
            </div>
            <div class="form-group">
                <label class="form-label-custom">NIT</label>
                <input asp-for="Nit" class="form-control-custom" placeholder="900.123.456-7"/>
                <span asp-validation-for="Nit" style="color:var(--color-danger); font-size:12px"></span>
            </div>
            <div class="form-group">
                <label class="form-label-custom">Teléfono</label>
                <input asp-for="Telefono" class="form-control-custom" placeholder="300 000 0000"/>
            </div>
            <div class="form-group">
                <label class="form-label-custom">Correo electrónico</label>
                <input asp-for="Email" type="email" class="form-control-custom" placeholder="contacto@empresa.com"/>
            </div>
            <div class="form-group" style="grid-column: span 3">
                <label class="form-label-custom">Dirección</label>
                <input asp-for="Direccion" class="form-control-custom" placeholder="Calle, carrera, barrio, ciudad"/>
            </div>
        </div>
    </div>

    <div style="display:flex; gap:12px; justify-content:flex-end; margin-bottom:32px">
        <a asp-action="Index" class="btn-secondary-custom">
            <i class="bi bi-x-lg"></i> Cancelar
        </a>
        <button type="submit" class="btn-primary-custom">
            <i class="bi bi-check-lg"></i> Guardar Cliente
        </button>
    </div>
</form>
